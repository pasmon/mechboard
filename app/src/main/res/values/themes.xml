<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Mechboard" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!--
        Keyboard colour themes.
        Each style defines the four ?attr/ values consumed by res/layout/input.xml
        and res/drawable/key_background.xml. They are applied at inflation time via
        ContextThemeWrapper in MechboardService.onCreateInputView().
    -->

    <!-- Dark — default dark theme (original Mechboard palette) -->
    <style name="Theme.Mechboard.Keyboard.Dark" parent="Theme.Mechboard">
        <item name="keyboardBgColor">@color/theme_dark_bg</item>
        <item name="keyBgColor">@color/theme_dark_key</item>
        <item name="keyPressedColor">@color/theme_dark_accent</item>
        <item name="keyLabelColor">@color/theme_dark_label</item>
    </style>

    <!-- Solarized Dark — Ethan Schoonover's low-contrast dark palette -->
    <style name="Theme.Mechboard.Keyboard.SolarizedDark" parent="Theme.Mechboard">
        <item name="keyboardBgColor">@color/theme_solarized_dark_bg</item>
        <item name="keyBgColor">@color/theme_solarized_dark_key</item>
        <item name="keyPressedColor">@color/theme_solarized_dark_accent</item>
        <item name="keyLabelColor">@color/theme_solarized_dark_label</item>
    </style>

    <!-- Solarized Light — Ethan Schoonover's low-contrast light palette -->
    <style name="Theme.Mechboard.Keyboard.SolarizedLight" parent="Theme.Mechboard">
        <item name="keyboardBgColor">@color/theme_solarized_light_bg</item>
        <item name="keyBgColor">@color/theme_solarized_light_key</item>
        <item name="keyPressedColor">@color/theme_solarized_light_accent</item>
        <item name="keyLabelColor">@color/theme_solarized_light_label</item>
    </style>

    <!-- Dracula — purple-tinted dark theme by Zeno Rocha -->
    <style name="Theme.Mechboard.Keyboard.Dracula" parent="Theme.Mechboard">
        <item name="keyboardBgColor">@color/theme_dracula_bg</item>
        <item name="keyBgColor">@color/theme_dracula_key</item>
        <item name="keyPressedColor">@color/theme_dracula_accent</item>
        <item name="keyLabelColor">@color/theme_dracula_label</item>
    </style>

    <!-- Nord — arctic blue-grey palette by Arctic Ice Studio -->
    <style name="Theme.Mechboard.Keyboard.Nord" parent="Theme.Mechboard">
        <item name="keyboardBgColor">@color/theme_nord_bg</item>
        <item name="keyBgColor">@color/theme_nord_key</item>
        <item name="keyPressedColor">@color/theme_nord_accent</item>
        <item name="keyLabelColor">@color/theme_nord_label</item>
    </style>

    <!-- Monokai — classic editor theme by Wimer Hazenberg -->
    <style name="Theme.Mechboard.Keyboard.Monokai" parent="Theme.Mechboard">
        <item name="keyboardBgColor">@color/theme_monokai_bg</item>
        <item name="keyBgColor">@color/theme_monokai_key</item>
        <item name="keyPressedColor">@color/theme_monokai_accent</item>
        <item name="keyLabelColor">@color/theme_monokai_label</item>
    </style>

    <!--
        Settings Activity themes.
        Each mirrors the colour palette of the corresponding keyboard theme so
        the settings screen feels consistent with the keyboard the user has chosen.
        Applied in SettingsActivity.onCreate() via setTheme() before super.onCreate().
        Palette colours are shared with keyboard themes via @color/ references in colors.xml.
    -->

    <!-- Dark — default dark theme (original Mechboard palette) -->
    <style name="Theme.Mechboard.Settings.Dark" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/theme_dark_key</item>
        <item name="colorPrimaryDark">@color/theme_dark_bg</item>
        <item name="colorAccent">@color/theme_dark_accent</item>
        <item name="android:colorBackground">@color/theme_dark_bg</item>
        <item name="android:textColorPrimary">@color/theme_dark_label</item>
        <item name="android:textColorSecondary">#CCCCCC</item>
    </style>

    <!-- Solarized Dark -->
    <style name="Theme.Mechboard.Settings.SolarizedDark" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/theme_solarized_dark_key</item>
        <item name="colorPrimaryDark">@color/theme_solarized_dark_bg</item>
        <item name="colorAccent">@color/theme_solarized_dark_accent</item>
        <item name="android:colorBackground">@color/theme_solarized_dark_bg</item>
        <item name="android:textColorPrimary">@color/theme_solarized_dark_label</item>
        <item name="android:textColorSecondary">@color/theme_solarized_light_label</item>
    </style>

    <!-- Solarized Light -->
    <style name="Theme.Mechboard.Settings.SolarizedLight" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/theme_solarized_light_key</item>
        <item name="colorPrimaryDark">@color/theme_solarized_light_bg</item>
        <item name="colorAccent">@color/theme_solarized_light_accent</item>
        <item name="android:colorBackground">@color/theme_solarized_light_bg</item>
        <item name="android:textColorPrimary">@color/theme_solarized_light_label</item>
        <item name="android:textColorSecondary">@color/theme_solarized_dark_label</item>
    </style>

    <!-- Dracula -->
    <style name="Theme.Mechboard.Settings.Dracula" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/theme_dracula_key</item>
        <item name="colorPrimaryDark">@color/theme_dracula_bg</item>
        <item name="colorAccent">@color/theme_dracula_accent</item>
        <item name="android:colorBackground">@color/theme_dracula_bg</item>
        <item name="android:textColorPrimary">@color/theme_dracula_label</item>
        <item name="android:textColorSecondary">#CCCCCC</item>
    </style>

    <!-- Nord -->
    <style name="Theme.Mechboard.Settings.Nord" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/theme_nord_key</item>
        <item name="colorPrimaryDark">@color/theme_nord_bg</item>
        <item name="colorAccent">@color/theme_nord_accent</item>
        <item name="android:colorBackground">@color/theme_nord_bg</item>
        <item name="android:textColorPrimary">@color/theme_nord_label</item>
        <item name="android:textColorSecondary">#D8DEE9</item>
    </style>

    <!-- Monokai -->
    <style name="Theme.Mechboard.Settings.Monokai" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/theme_monokai_key</item>
        <item name="colorPrimaryDark">@color/theme_monokai_bg</item>
        <item name="colorAccent">@color/theme_monokai_accent</item>
        <item name="android:colorBackground">@color/theme_monokai_bg</item>
        <item name="android:textColorPrimary">@color/theme_monokai_label</item>
        <item name="android:textColorSecondary">#CCCCCC</item>
    </style>
</resources>
