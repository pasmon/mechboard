<?xml version="1.0" encoding="utf-8"?>
<!--
    State-list drawable for individual keys.
    Pressed state uses the accent colour; normal state uses keyBackground.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorAccent" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#44FFFFFF" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/keyBackground" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#22FFFFFF" />
        </shape>
    </item>

</selector>
