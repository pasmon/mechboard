<?xml version="1.0" encoding="utf-8"?>
<!--
    Spanish QWERTY keyboard definition.

    Differences from English QWERTY:
      - Row 1: long-press → digits 1–0
      - Row 2: a s d f g h j k l ñ  (10 keys @ 10 %p, no leading gap)
      - Row 4: ?123 ,  [space]  ¿  ¡  .  ↵
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:horizontalGap="0px"
    android:verticalGap="0px"
    android:keyHeight="@dimen/key_height">

    <!-- Row 1: q–p (long-press reveals digits 1–0) -->
    <Row>
        <Key android:codes="113" android:keyLabel="q" android:keyEdgeFlags="left"
             android:popupKeyboard="@xml/keyboard_popup" android:popupCharacters="1" />
        <Key android:codes="119" android:keyLabel="w"
             android:popupKeyboard="@xml/keyboard_popup" android:popupCharacters="2" />
        <Key android:codes="101" android:keyLabel="e"
             android:popupKeyboard="@xml/keyboard_popup" android:popupCharacters="3" />
        <Key android:codes="114" android:keyLabel="r"
             android:popupKeyboard="@xml/keyboard_popup" android:popupCharacters="4" />
        <Key android:codes="116" android:keyLabel="t"
             android:popupKeyboard="@xml/keyboard_popup" android:popupCharacters="5" />
        <Key android:codes="121" android:keyLabel="y"
             android:popupKeyboard="@xml/keyboard_popup" android:popupCharacters="6" />
        <Key android:codes="117" android:keyLabel="u"
             android:popupKeyboard="@xml/keyboard_popup" android:popupCharacters="7" />
        <Key android:codes="105" android:keyLabel="i"
             android:popupKeyboard="@xml/keyboard_popup" android:popupCharacters="8" />
        <Key android:codes="111" android:keyLabel="o"
             android:popupKeyboard="@xml/keyboard_popup" android:popupCharacters="9" />
        <Key android:codes="112" android:keyLabel="p" android:keyEdgeFlags="right"
             android:popupKeyboard="@xml/keyboard_popup" android:popupCharacters="0" />
    </Row>

    <!-- Row 2: a–l + ñ  (10 keys @ 10 %p, no leading gap) -->
    <Row>
        <Key android:codes="97"  android:keyLabel="a"  android:keyEdgeFlags="left" />
        <Key android:codes="115" android:keyLabel="s" />
        <Key android:codes="100" android:keyLabel="d" />
        <Key android:codes="102" android:keyLabel="f" />
        <Key android:codes="103" android:keyLabel="g" />
        <Key android:codes="104" android:keyLabel="h" />
        <Key android:codes="106" android:keyLabel="j" />
        <Key android:codes="107" android:keyLabel="k" />
        <Key android:codes="108" android:keyLabel="l" />
        <Key android:codes="241" android:keyLabel="ñ"  android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 3: Shift, z–m, Delete (same as English) -->
    <Row>
        <Key android:codes="-1"  android:keyLabel="⇧"
             android:keyWidth="15%p" android:keyEdgeFlags="left"
             android:isModifier="true" android:isSticky="true" />
        <Key android:codes="122" android:keyLabel="z" />
        <Key android:codes="120" android:keyLabel="x" />
        <Key android:codes="99"  android:keyLabel="c" />
        <Key android:codes="118" android:keyLabel="v" />
        <Key android:codes="98"  android:keyLabel="b" />
        <Key android:codes="110" android:keyLabel="n" />
        <Key android:codes="109" android:keyLabel="m" />
        <Key android:codes="-5"  android:keyLabel="⌫"
             android:keyWidth="15%p" android:keyEdgeFlags="right"
             android:isRepeatable="true" />
    </Row>

    <!-- Row 4: Symbols toggle, comma, Space, ¿, ¡, period, Enter -->
    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-102" android:keyLabel="@string/key_label_symbols"
             android:keyWidth="10%p" android:keyEdgeFlags="left" />
        <Key android:codes="44"   android:keyLabel=","   android:keyWidth="10%p" />
        <Key android:codes="32"   android:keyLabel="Space" android:keyWidth="40%p" />
        <Key android:codes="191"  android:keyLabel="¿"   android:keyWidth="10%p" />
        <Key android:codes="161"  android:keyLabel="¡"   android:keyWidth="10%p" />
        <Key android:codes="46"   android:keyLabel="."   android:keyWidth="10%p" />
        <Key android:codes="-4"   android:keyLabel="↵"
             android:keyWidth="10%p" android:keyEdgeFlags="right" />
    </Row>

</Keyboard>
